generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          Int    @id @default(autoincrement())
  name        String
  category    String
  price       Float
  image       String
  description String
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
